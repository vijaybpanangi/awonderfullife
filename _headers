# Cloudflare Workers static-assets headers.

# Images rarely change under the same name — cache hard for a year.
/assets/images/*
  Cache-Control: public, max-age=31536000, immutable

# CSS/JS use unversioned filenames and change between releases, so they must NOT be
# immutable (that pins stale styles/scripts in returning visitors' browsers for a year).
# Revalidate on every load — the files are tiny, so a 304 is cheap, and updates appear
# on a normal refresh.
/assets/css/*
  Cache-Control: public, max-age=0, must-revalidate
/assets/js/*
  Cache-Control: public, max-age=0, must-revalidate

# Security + privacy headers for everything.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), microphone=(), camera=()
