---
layout: base.njk
mainClass: "container container--post"
newsletter: true
hasComments: true
hasReactions: true
seoType: post
---
{%- import "card-grid.njk" as cardGrid -%}
        <div class="post-layout">
        <article data-pagefind-body data-pagefind-meta="category:{{ category | categoryName(site.categories) }}">
            <header class="post-header{% if heroTitled %} is-hero-titled{% endif %}">
                <a class="kicker" href="/categories/{{ category }}">{{ category | categoryName(site.categories) }}</a>
                <h1 data-pagefind-meta="title">{{ title | safe }}</h1>
                {%- if dek %}
                <p class="post-dek"><em>{{ dek | safe }}</em></p>
                {%- endif %}
                <p class="post-byline" data-pagefind-meta="date:{{ date | isoDate }}">{{ site.author | upper }} · {{ date | bylineDate }} · {{ minRead or (content | readingTime) }} MIN READ</p>
            </header>
            <img class="post-hero" src="/assets/images/posts/{{ page.fileSlug }}.jpg" alt="{{ heroAlt | safe }}">
            <div class="post-content">
                {{ content | safe }}
            </div>
{%- include "post-nav.njk" %}
        </article>
        <aside class="post-aside">
{% include "author-card.njk" %}
        </aside>
        </div>

        <section class="reactions" data-slug="{{ page.fileSlug }}"></section>

{% set related = collections.posts | relatedPosts(page, category, 3) %}
{% if related.length %}
        <section class="related-posts">
            <h2 class="related-posts-title">More reading</h2>
            <ul class="card-grid card-grid--3">
        {%- for post in related %}
{{ cardGrid.card(post, true, site.categories) }}
        {%- endfor %}
            </ul>
        </section>
{% endif %}

        <section id="comments" class="comments" data-slug="{{ page.fileSlug }}"></section>
