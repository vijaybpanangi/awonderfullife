{#- Canonical + Open Graph + Twitter Card tags. Mirrors the block
   docs/superpowers/tools/seo-inject.py appends to every legacy page. Expects
   `seoType` ("home"|"about"|"archive"|"category"|"post"), `fullTitle`
   (the <title> text), `description` (raw, as copied from the legacy meta
   attribute), and for posts: `category`, `date`. -#}
{%- set canonicalUrl = page.url | cleanUrl | absoluteUrl(site.url) -%}
{%- set ogType = "article" if seoType == "post" else "website" -%}
{%- if seoType == "post" -%}
{%- set ogImagePath = "/assets/images/posts/" + page.fileSlug + ".jpg" -%}
{%- set ogImageAlt = heroAlt -%}
{%- elif seoType == "about" -%}
{%- set ogImagePath = "/assets/images/vijay.jpg" -%}
{%- set ogImageAlt = "Portrait of " + site.author -%}
{%- else -%}
{%- set ogImagePath = "/assets/images/og-default.jpg" -%}
{%- set ogImageAlt = site.name + " - " + site.tagline -%}
{%- endif -%}
{%- set ogImage = ogImagePath | absoluteUrl(site.url) -%}
{%- set ogDims = ogImagePath | imageDims %}
    <link rel="canonical" href="{{ canonicalUrl }}">
    <meta property="og:site_name" content="{{ site.name }}">
    <meta property="og:locale" content="en_CA">
    <meta property="og:type" content="{{ ogType }}">
    <meta property="og:title" content="{{ fullTitle | safe }}">
    <meta property="og:description" content="{{ description | safe }}">
    <meta property="og:url" content="{{ canonicalUrl }}">
    <meta property="og:image" content="{{ ogImage }}">
    <meta property="og:image:alt" content="{{ ogImageAlt | safe }}">
    {%- if ogDims %}
    <meta property="og:image:width" content="{{ ogDims.width }}">
    <meta property="og:image:height" content="{{ ogDims.height }}">
    {%- endif %}
    {%- if seoType == "post" %}
    <meta property="article:published_time" content="{{ date | isoDate }}">
    <meta property="article:modified_time" content="{{ (updated or date) | isoDate }}">
    <meta property="article:author" content="{{ site.author }}">
    <meta property="article:section" content="{{ category | categoryName(site.categories) }}">
    {%- endif %}
    <meta name="twitter:card" content="summary_large_image">
    {%- if site.twitterHandle %}
    <meta name="twitter:site" content="{{ site.twitterHandle }}">
    <meta name="twitter:creator" content="{{ site.twitterHandle }}">
    {%- endif %}
    <meta name="twitter:title" content="{{ fullTitle | safe }}">
    <meta name="twitter:description" content="{{ description | safe }}">
    <meta name="twitter:image" content="{{ ogImage }}">
    <meta name="twitter:image:alt" content="{{ ogImageAlt | safe }}">
