# Paths excluded from the Cloudflare Worker asset upload.
# Anything matched here will NOT be publicly served at awonderfullife.ca.

# Git internals — never expose, prevents `git clone` from the live URL.
.git
.git/**

# Wrangler local cache and dev artifacts.
.wrangler
.wrangler/**
.dev.vars
.dev.vars.*
.env
.env.*

# Brainstorming session files (also in .gitignore).
.superpowers
.superpowers/**

# Staging source images (pre-optimization) — not served; processed copies live in assets/images/.
assets/staging-images
assets/staging-images/**

# Repo metadata and docs that shouldn't be public assets.
.gitignore
.assetsignore
wrangler.jsonc
README.md
CLAUDE.md
CHANGELOG.md
ROADMAP.md
docs
docs/**

# API worker — a separate Cloudflare Worker (api.awonderfullife.ca), never a static asset of the site.
api
api/**
node_modules
node_modules/**

# Eleventy build pipeline (feat/eleventy-migration) — interim safety while the
# legacy root HTML is still what's actually deployed. Build tooling and its
# generated output must never be publicly served alongside the live site.
package.json
package-lock.json
eleventy.config.js
eleventy
eleventy/**
src
src/**
scripts
scripts/**
_site
_site/**
